# 环境变量（包含本地路径和密钥，不能上传）
.env

# 数据目录（用户自备的词典和用户数据，不随代码分发）
easydict-data/

# 旧数据目录（已弃用，需要系统管理员手动清理）
# 这些目录由早期的 Docker 运行创建，权限由 root 管理
# 可安全删除：rm -rf dicts/ data/ docker/data/
dicts/
data/
docker/data/

# Large database files
auxi/en.db

# 运行时日志
logs/

# 用户数据库（运行时生成）
contributor_data/

# Python 缓存
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# IDE / 编辑器配置
.claude/
.vscode/
.idea/

# 系统文件
.DS_Store
Thumbs.db
