# EasyDict Cloud - Environment Configuration Example
# Copy this file to .env and fill in the appropriate values

# ============================================================
# JWT Authentication
# ============================================================
# REQUIRED: JWT secret key for token signing and verification
# Generate a secure random value:
#   python -c 'import secrets; print(secrets.token_hex(32))'
JWT_SECRET=your_secure_jwt_secret_here_32_hex_chars_minimum

# ============================================================
# Data Storage Path
# ============================================================
# Root path for all application data
# The system will automatically create subdirectories:
#   - {DATA_PATH}/dictionaries (词典数据)
#   - {DATA_PATH}/user (用户数据)
#   - {DATA_PATH}/auxiliary (辅助文件如 en.db)
# Default: ./easydict-data (relative to docker-compose.yml)
DATA_PATH=./easydict-data

# ============================================================
# File Size Limits (in bytes)
# ============================================================
# Maximum size for user settings ZIP file
# Default: 10485760 (10MB)
MAX_SETTINGS_FILE_SIZE=10485760

# Maximum size for metadata.json files
# Default: 5242880 (5MB)
MAX_METADATA_FILE_SIZE=5242880

# Maximum size for dictionary.db files
# Default: 524288000 (500MB)
MAX_DICTIONARY_FILE_SIZE=524288000

# Maximum size for media.db files (contains audio/images)
# Default: 2147483648 (2GB)
MAX_MEDIA_FILE_SIZE=2147483648

# Maximum size for compressed entries (.zst) files
# Default: 524288000 (500MB)
MAX_ENTRIES_FILE_SIZE=524288000

# ============================================================
# API Service Configuration
# ============================================================
# Internal URL for API service (used by user service)
# Default: http://api:8080 (Docker network)
# Change if running non-containerized or different network
API_INTERNAL_URL=http://api:8080

# Logging level (info, debug, warning, error)
# Default: info
LOG_LEVEL=info

# ============================================================
# Database Configuration
# ============================================================
# SQLite database file for user service
# Default: $USER_DATA_PATH/user.db
# (Automatically created if not present)

# ============================================================
# Port Configuration (Docker Compose)
# ============================================================
# Nginx reverse proxy listening port
# Default: 3070
NGINX_PORT=3070

# API service listening port
# Default: 8080
API_PORT=8080

# User service listening port
# Default: 8000
USER_PORT=8000

# ============================================================
# Security Notes
# ============================================================
# 1. JWT_SECRET: Must be a long, random, cryptographically secure string.
#    - Generate fresh secret before deployment
#    - Never share or commit JWT_SECRET
#    - Changing JWT_SECRET will invalidate all existing tokens
#
# 2. File size limits protect against:
#    - Memory exhaustion attacks (DoS)
#    - Zip bomb attacks (decompression bomb)
#    - Disk space exhaustion
#
# 3. Entry ID bounds protect against:
#    - Negative entry ID injection
#    - Integer overflow attacks
#    - SQL injection via numeric parameters
#
# 4. Path traversal protection:
#    - Audio and image files are validated to prevent ../../../ attacks
#    - Resolved paths must be within dictionary directory

# ============================================================
# Docker Compose Override
# ============================================================
# Uncomment and modify below to override defaults in docker-compose.yml
# Example for custom path:
#
# DATA_PATH=/mnt/storage
